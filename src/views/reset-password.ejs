<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password</title>
    <style>
      :root {
        --bg: #f2f6f5;
        --card: #ffffff;
        --text: #13201f;
        --muted: #5f7572;
        --primary: #0d7a76;
        --danger: #c23a3a;
        --success: #1d7f42;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        min-height: 100vh;
        font-family: Arial, sans-serif;
        background: radial-gradient(circle at 20% 0%, #dbeee9, var(--bg) 55%);
        color: var(--text);
        display: grid;
        place-items: center;
        padding: 20px;
      }
      .card {
        width: 100%;
        max-width: 460px;
        background: var(--card);
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 20px 35px rgba(13, 122, 118, 0.12);
      }
      h1 {
        margin: 0 0 10px;
        font-size: 24px;
      }
      .account {
        margin: 0 0 18px;
        font-size: 14px;
        color: var(--muted);
      }
      form {
        display: grid;
        gap: 14px;
      }
      label {
        display: grid;
        gap: 6px;
        font-size: 14px;
      }
      input[type="password"],
      input[type="text"] {
        width: 100%;
        border: 1px solid #c7d7d4;
        border-radius: 10px;
        padding: 11px 12px;
        font-size: 15px;
      }
      .toggle {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        color: var(--muted);
      }
      button {
        border: 0;
        border-radius: 10px;
        padding: 12px;
        background: var(--primary);
        color: #fff;
        font-size: 15px;
        cursor: pointer;
      }
      .message {
        border-radius: 10px;
        padding: 10px 12px;
        font-size: 14px;
      }
      .error {
        background: #fdeaea;
        color: var(--danger);
      }
      .success {
        background: #e8f7ee;
        color: var(--success);
      }
    </style>
  </head>
  <body>
    <main class="card">
      <h1>Reset Your Password</h1>
      <p class="account">
        Account: <strong><%= username %></strong>
        <% if (displayName) { %> (<%= displayName %>) <% } %>
      </p>

      <% if (error) { %>
      <div class="message error"><%= error %></div>
      <% } %>
      <% if (success) { %>
      <div class="message success"><%= success %></div>
      <% } %>

      <form method="POST" action="<%= actionUrl %>">
        <label>
          New Password
          <input id="password" type="password" name="password" required minlength="6" />
        </label>

        <label>
          Confirm Password
          <input
            id="confirmPassword"
            type="password"
            name="confirmPassword"
            required
            minlength="6"
          />
        </label>

        <label class="toggle">
          <input id="showPassword" type="checkbox" />
          Show password text
        </label>

        <button type="submit">Update Password</button>
      </form>
    </main>

    <script>
      const toggle = document.getElementById('showPassword');
      const password = document.getElementById('password');
      const confirmPassword = document.getElementById('confirmPassword');

      toggle.addEventListener('change', () => {
        const mode = toggle.checked ? 'text' : 'password';
        password.type = mode;
        confirmPassword.type = mode;
      });
    </script>
  </body>
</html>
